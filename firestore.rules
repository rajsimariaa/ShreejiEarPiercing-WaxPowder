rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /bookings/{bookingId} {
      // Allow any logged-in user to create a booking
      allow create: if request.auth != null 
        && request.resource.data.name is string
        && request.resource.data.phone is string
        && request.resource.data.visitType in ['visit-us', 'visit-home']
        && request.resource.data.address is string;
      
      // Access Control:
      // 1. Users can read only their own bookings
      // 2. The Admin (Geeta) can read all bookings
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.auth.token.email == 'geetasimaria1958@gmail.com'
      );
      
      // Only the Admin (Geeta) can mark as completed (update status) or delete
      allow update, delete: if request.auth != null && 
        request.auth.token.email == 'geetasimaria1958@gmail.com';
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
